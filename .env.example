# Local development: copy to .env and fill in your keys.
# For Streamlit Cloud, copy these into "Secrets" in the Advanced settings, not as a .env file.

GROQ_API_KEY=
# Optional fallback when Groq rate-limits (429) or payload is too large (413):
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GROQ_MODEL=llama-3.3-70b-versatile
APP_PASSWORD=
PORTFOLIO_URL=https://github.com/yourusername
DEBUG_MODE=false
