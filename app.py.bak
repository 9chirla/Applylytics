def _groq_api_key() -> str:
    """Prefer GROQ_API_KEY so a separate Groq account can override OPENAI_API_KEY."""
    return (os.getenv("GROQ_API_KEY") or os.getenv("OPENAI_API_KEY") or "").strip()


